# ── Anthropic ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS Secrets Manager ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# ── Twilio ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Axis CRM ─────────────────────────────────────────────────────
AXIS_CRM_API_URL=https://your-axis-instance.com/api/v1
AXIS_CRM_API_TOKEN=

# ── Worker settings ──────────────────────────────────────────────
MAX_WORKER_CONCURRENCY=5
CLAUDE_MAX_TURNS=12
LOG_LEVEL=INFO
